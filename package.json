{
  "name": "commanddeck",
  "version": "0.1.0",
  "description": "A toggle board for terminal commands",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test test/*.test.js",
    "icon": "node scripts/export-icon.js",
    "postinstall": "patch-package && electron-rebuild"
  },
  "keywords": [
    "electron",
    "terminal",
    "commands",
    "productivity",
    "linux"
  ],
  "author": "Jason Millikan",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-rebuild": "^3.2.9",
    "patch-package": "^8.0.1"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "sortablejs": "^1.15.7",
    "xterm": "^4.19.0",
    "xterm-addon-fit": "^0.5.0"
  }
}
